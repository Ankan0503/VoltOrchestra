DATABASE_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appName>
DB_NAME=voltorchestra_db
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
JWT_SECRET_KEY=your-jwt-secret-key-here
CORS_ALLOW_ALL_ORIGINS=True

# HiveMQ Cloud MQTT Configuration
MQTT_BROKER=your-cluster-id.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_WEBSOCKET_PORT=8884
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password
